rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Productos ---
    match /products/{productId} {
      // Permitir que cualquier usuario autenticado lea los productos.
      allow read: if request.auth != null;
      // Solo los administradores pueden crear, actualizar o borrar productos.
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // --- Pedidos ---
    match /orders/{orderId} {
      // Un usuario autenticado puede crear un pedido a su nombre.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Un usuario solo puede leer los pedidos que le pertenecen.
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // No se pueden actualizar ni borrar pedidos una vez creados.
      allow update, delete: if false;
    }

    // --- Usuarios y su Biblioteca ---
    match /users/{userId} {
      // Un usuario puede leer y escribir en su propio documento.
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Reglas para la subcolección 'library'
      match /library/{gameId} {
        // Un usuario puede leer y escribir (añadir/actualizar juegos) en su propia biblioteca.
        allow read, write: if request.auth != null && request.auth.uid == userId;
        // No se pueden borrar juegos de la biblioteca directamente (se podría implementar una función si se desea).
        allow delete: if false;
      }
    }
  }
}
