rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección 'products'
    match /products/{productId} {
      // Lectura permitida para cualquier usuario autenticado.
      allow read: if request.auth != null;

      // Escritura (crear, actualizar, borrar) permitida SOLO para administradores.
      // Verificamos el "custom claim" 'admin' en el token de autenticación.
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Reglas para la colección 'users'
    match /users/{userId} {
      // Cualquiera puede crear su propio documento de usuario (al registrarse).
      allow create: if request.auth != null && request.auth.uid == userId;

      // Un usuario solo puede leer su propio documento.
      allow read: if request.auth != null && request.auth.uid == userId;

      // Un usuario solo puede actualizar su propio documento.
      allow update: if request.auth != null && request.auth.uid == userId;

      // Los usuarios no pueden borrarse a sí mismos (por seguridad).
      allow delete: if false;
    }
  }
}
